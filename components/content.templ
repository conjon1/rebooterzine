package components

templ ContentView() {
	<section id="content-view" class="page min-h-screen hidden">
		<div class="fade-in">
			<button id="back-btn" class="mb-8 text-[#c678dd] hover:text-[#61afef] transition-transform hover:-translate-x-1">
				&larr; Back
			</button>
			<div id="dynamic-content" class="prose max-w-none"></div>
		</div>
	</section>
}
